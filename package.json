{
  "name": "@rlippmann/context-compiler-directive-drafter",
  "version": "0.1.0",
  "description": "TypeScript acquisition-layer utilities for Context Compiler directive drafting.",
  "keywords": [
    "context-compiler",
    "directive-drafter",
    "typescript",
    "llm"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rlippmann/context-compiler-directive-drafter-ts.git"
  },
  "homepage": "https://github.com/rlippmann/context-compiler-directive-drafter-ts#readme",
  "bugs": {
    "url": "https://github.com/rlippmann/context-compiler-directive-drafter-ts/issues"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json",
    "fixtures:preprocessor:sync": "bash scripts/preprocessor-fixtures-sync.sh",
    "fixtures:preprocessor:check": "bash scripts/preprocessor-fixtures-check.sh",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "smoke:pack-import": "rm -rf /tmp/context-compiler-directive-drafter-pack-smoke && mkdir -p /tmp/context-compiler-directive-drafter-pack-smoke && npm pack --pack-destination /tmp/context-compiler-directive-drafter-pack-smoke && node scripts/package-import-smoke.mjs /tmp/context-compiler-directive-drafter-pack-smoke",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "^3.2.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
